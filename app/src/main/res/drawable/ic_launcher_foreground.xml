<?xml version="1.0" encoding="utf-8"?>
<!--
  Obsidian app icon foreground — habit progress ring at ~68% with a
  diamond "streak" marker, in the luminous teal accent (#57E6C6).
  Safe zone: center 66dp of the 108dp viewport.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Faint full track ring -->
    <path
        android:pathData="M54,32 A22,22 0 1,1 53.99,32"
        android:strokeColor="#22FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Accent progress arc (~68%, from 12 o'clock clockwise) -->
    <path
        android:pathData="M54,32 A22,22 0 1,1 33.5,45.7"
        android:strokeColor="#57E6C6"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />

    <!-- Diamond streak marker in the center -->
    <path
        android:pathData="M54,47 L61,54 L54,61 L47,54 Z"
        android:fillColor="#57E6C6" />
</vector>
